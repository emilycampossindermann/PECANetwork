{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/cards/**",
              "components/core/**",
              "components/feedback/**",
              "components/forms/**",
              "components/layout/**",
              "components/navigation/**",
              "ui_kits/marketing-site/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Manrope|Inter|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Manrope, Inter, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|kind|uppercase|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, kind, uppercase."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='kind'] > Literal[value!=/^(?:neutral|blue|violet|mint|peach|dark)$/]",
        "message": "<Badge> kind must be one of 'neutral' | 'blue' | 'violet' | 'mint' | 'peach' | 'dark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|icon|iconPosition|disabled|onClick|type|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, icon, iconPosition, disabled, onClick, type, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|onColor)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'onColor'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='iconPosition'] > Literal[value!=/^(?:left|right)$/]",
        "message": "<Button> iconPosition must be one of 'left' | 'right'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit)$/]",
        "message": "<Button> type must be one of 'button' | 'submit'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CalloutChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|description|accent|key|ref|className|style|children)$/]",
        "message": "<CalloutChip> doesn't accept that prop. Declared props: label, description, accent."
      },
      {
        "selector": "JSXOpeningElement[name.name='CalloutChip'] > JSXAttribute[name.name='accent'] > Literal[value!=/^(?:blue|violet|mint|peach)$/]",
        "message": "<CalloutChip> accent must be one of 'blue' | 'violet' | 'mint' | 'peach'."
      },
      {
        "selector": "JSXOpeningElement[name.name='FooterColumn'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|links|key|ref|className|style|children)$/]",
        "message": "<FooterColumn> doesn't accept that prop. Declared props: title, links."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|placeholder|type|value|onChange|focused|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, placeholder, type, value, onChange, focused."
      },
      {
        "selector": "JSXOpeningElement[name.name='PublicationCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|authors|date|journal|badge|imageAccent|key|ref|className|style|children)$/]",
        "message": "<PublicationCard> doesn't accept that prop. Declared props: title, authors, date, journal, badge, imageAccent."
      },
      {
        "selector": "JSXOpeningElement[name.name='PublicationCard'] > JSXAttribute[name.name='imageAccent'] > Literal[value!=/^(?:blue|violet|mint)$/]",
        "message": "<PublicationCard> imageAccent must be one of 'blue' | 'violet' | 'mint'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TopNavLink'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|href|key|ref|className|style|children)$/]",
        "message": "<TopNavLink> doesn't accept that prop. Declared props: label, href."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
